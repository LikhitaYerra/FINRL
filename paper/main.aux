\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Supervised forecasting baselines. Ridge models predict 5-day forward returns from price/technical features alone, price plus LLM sentiment or four-factor semantics, price plus lexical dense headlines (VADER; train-fit TF--IDF/SVD), optional FinBERT tone when available, or a semantic tilt. Ridge strength and the semantic tilt are selected on 2018 validation Sharpe, refit on 2013--2018, and evaluated once on 2019--2023 using the same daily top-10 portfolio rule as SFP.}}{7}{table.4}\protected@file@percent }
\newlabel{tab:supervised_forecasting}{{4}{7}{Supervised forecasting baselines. Ridge models predict 5-day forward returns from price/technical features alone, price plus LLM sentiment or four-factor semantics, price plus lexical dense headlines (VADER; train-fit TF--IDF/SVD), optional FinBERT tone when available, or a semantic tilt. Ridge strength and the semantic tilt are selected on 2018 validation Sharpe, refit on 2013--2018, and evaluated once on 2019--2023 using the same daily top-10 portfolio rule as SFP}{table.4}{}}
